# KDP MasterPeace — environment example. Copy to .env (git-ignored) and fill in.
# NEVER commit real values or service-account JSON.

# --- Firebase Web client (PUBLIC identifiers, injected into the studio-web build) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# --- Firebase Admin (SERVER only — server functions verifying ID tokens) ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Keep the literal \n escapes; the server normalizes them to real newlines.
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Local development: use the Firebase Emulator Suite (no real project needed) ---
# `firebase emulators:start` serves Auth (9099) + Firestore (8080). The dev build
# (environment.ts) already points at these; no values above are required locally.

# --- AI / research / image providers (SERVER only — added in later packages) ---
ANTHROPIC_API_KEY=
SEARCH_PROVIDER_API_KEY=
HIGGSFIELD_API_KEY=
