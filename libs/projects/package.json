{
  "name": "@kdp/projects",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "projects",
    "tags": [
      "platform:any",
      "type:feature"
    ],
    "targets": {
      "test-integration": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run integration",
          "cwd": "libs/projects"
        }
      }
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "@kdp/contracts": "*"
  }
}
