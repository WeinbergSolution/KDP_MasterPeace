{
  "name": "@kdp/source",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema apps/api/prisma/schema.prisma",
    "format:check": "prettier --check .",
    "sync": "nx sync",
    "sync:check": "nx sync:check",
    "format:write": "prettier --write .",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "test:integration": "nx run-many -t test-integration",
    "test:integration:postgres": "nx test-integration projects-prisma",
    "test:e2e:smoke": "nx run-many -t e2e-smoke",
    "build": "nx run-many -t build",
    "db:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema apps/api/prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "check:file-size": "node tools/checks/check-file-size.mjs",
    "check:function-size": "node tools/checks/check-function-size.mjs",
    "check:jsdoc": "node tools/checks/check-jsdoc.mjs",
    "check:console": "node tools/checks/check-console.mjs",
    "check:architecture": "nx run-many -t lint --parallel=1",
    "check:responsive": "node tools/checks/check-responsive.mjs",
    "check:frontend-secrets": "node tools/checks/check-frontend-secrets.mjs",
    "test:wp-c1": "node tools/e2e/wp-c1-smoke.mjs",
    "checks": "npm run check:file-size && npm run check:function-size && npm run check:jsdoc && npm run check:console"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "^23.0.1",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/nest": "^23.0.1",
    "@nx/node": "23.0.1",
    "@nx/vite": "^23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/webpack": "23.0.1",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "~0.2.38",
    "@types/jest": "~30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "~4.1.0",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "~21.2.0",
    "nx": "23.0.1",
    "playwright": "^1.61.1",
    "postcss": "^8.4.5",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/ai-providers/*"
  ],
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma",
    "seed": "tsx apps/api/prisma/seed.ts"
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.5",
    "@prisma/client": "^6.19.3",
    "axios": "^1.6.0",
    "bullmq": "^5.80.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.25.76"
  }
}
