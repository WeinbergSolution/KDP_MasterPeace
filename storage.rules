rules_version = '2';

// Storage is not activated yet (assets land with a later package). These rules
// are ready: each user may only access their own object prefix. No public access.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
